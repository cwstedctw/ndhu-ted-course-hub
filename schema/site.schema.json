{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hub.ndhu-ted/schema/site.schema.json",
  "title": "site.json — 全站設定",
  "type": "object",
  "additionalProperties": false,
  "required": ["brand", "baseUrl", "scoreUrl", "scoreDemoUrl", "about", "footerCredits", "buildLog"],
  "properties": {
    "brand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "semester", "description", "palette"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "semester": { "$ref": "_defs.schema.json#/$defs/semester" },
        "description": { "type": ["string", "null"] },
        "palette": {
          "type": "object",
          "additionalProperties": false,
          "required": ["teal", "gold", "cream", "ink"],
          "properties": {
            "teal": { "const": "#0E7C7B" },
            "gold": { "const": "#D9A441" },
            "cream": { "const": "#F4ECD8" },
            "ink": { "const": "#1A1A1A" }
          }
        }
      }
    },
    "baseUrl": { "$ref": "_defs.schema.json#/$defs/nullableHttpsUrl" },
    "scoreUrl": { "$ref": "_defs.schema.json#/$defs/scoreV2Url" },
    "scoreDemoUrl": { "$ref": "_defs.schema.json#/$defs/nullableHttpsUrl" },
    "weekOneStart": {
      "description": "第 1 週週一日期（YYYY-MM-DD；學期行事曆真值）。null＝未定，課程頁「本週」高亮休眠（2026-07-05 學生視角升級）",
      "type": ["string", "null"],
      "format": "date"
    },
    "scoreDisputeUrl": {
      "description": "成績複查表單連結。null＝開學前未定，成績頁出「開學後提供」占位句",
      "$ref": "_defs.schema.json#/$defs/nullableHttpsUrl"
    },
    "enrollUrl": {
      "description": "學校選課系統入口。null＝未定，課程頁不出「怎麼選課」chip",
      "$ref": "_defs.schema.json#/$defs/nullableHttpsUrl"
    },
    "about": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "email", "office", "contact"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "office": { "type": "string", "minLength": 1 },
        "contact": { "type": "string", "minLength": 1 },
        "contactNote": {
          "description": "聯絡方式下的回覆預期小字（降低學生催問焦慮；null／缺＝不出）。2026-07-05 學生視角升級",
          "type": ["string", "null"]
        }
      }
    },
    "footerCredits": { "type": "string", "minLength": 1 },
    "buildLog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    }
  }
}
