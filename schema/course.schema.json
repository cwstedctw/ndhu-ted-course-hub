{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hub.ndhu-ted/schema/course.schema.json",
  "title": "course.json — 課程詳細（course-intro.json 超集＋hub）",
  "type": "object",
  "required": ["id", "kind", "name", "nameEn", "semester", "org", "instructor",
               "credits", "courseType", "weeksSystem", "sections", "intro", "meta", "hub"],
  "properties": {
    "kind": { "enum": ["regular", "lecture-series"] },
    "semester": { "$ref": "_defs.schema.json#/$defs/semester" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string", "pattern": "^[A-Z]{2}$" } }
      }
    },
    "intro": {
      "type": "object",
      "properties": { "internalNotes": false }
    },
    "hub": { "$ref": "#/$defs/hub" }
  },
  "$defs": {
    "hub": {
      "type": "object",
      "additionalProperties": false,
      "required": ["links", "showcaseRefs", "heroImage", "showPromptButtons"],
      "properties": {
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["platform", "use", "label", "url", "urlStatus"],
            "properties": {
              "platform": { "enum": ["teams", "zuvio", "hackmd", "elearn", "classroom", "other"] },
              "use": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "url": { "$ref": "_defs.schema.json#/$defs/nullableHttpsUrl" },
              "urlStatus": { "enum": ["pending", "confirmed"] }
            },
            "allOf": [
              {
                "if": { "properties": { "urlStatus": { "const": "confirmed" } } },
                "then": { "properties": { "url": { "type": "string" } } }
              },
              {
                "if": { "properties": { "url": { "type": "null" } } },
                "then": { "properties": { "urlStatus": { "const": "pending" } } }
              }
            ]
          }
        },
        "scoreUrl": { "$ref": "_defs.schema.json#/$defs/nullableScoreV2Url" },
        "showcaseRefs": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^\\d{4}-[a-z0-9]+(-[a-z0-9]+)*-\\d{2}$" }
        },
        "heroImage": {
          "anyOf": [ { "type": "string", "pattern": "^/images/courses/" }, { "type": "null" } ]
        },
        "showPromptButtons": { "type": "boolean" }
      }
    }
  }
}
